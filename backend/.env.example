PORT=5000
NODE_ENV=development

# ─── MongoDB ────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/finvault
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/finvault
MONGO_URI=mongodb://localhost:27017/finvault

# ─── JWT Secrets ────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=change_this_to_another_long_random_string_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Cookies ────────────────────────────────────────────────────
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ─── Email (Gmail App Password) ─────────────────────────────────
# Setup: myaccount.google.com → Security → App Passwords → Generate
# IMPORTANT: Do NOT put quotes around EMAIL_FROM value!
# WRONG:   EMAIL_FROM="FinVault <you@gmail.com>"   <- quotes break it
# CORRECT: EMAIL_FROM=FinVault <you@gmail.com>
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_actual_gmail@gmail.com
EMAIL_PASS=abcd efgh ijkl mnop
EMAIL_FROM=FinVault <your_actual_gmail@gmail.com>

# ─── Frontend URL ───────────────────────────────────────────────
CLIENT_URL=https://finvaultfinance.vercel.app/

# ─── File Upload ─────────────────────────────────────────────────
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
